# =============================================================================
# .gitignore — Multimodal SSL Preprocessing Pipeline
# =============================================================================

# ---------------------------------------------------------------------------
# Raw, interim, and processed data — not committed (regenerated by pipeline)
# ---------------------------------------------------------------------------
data/raw/
data/interim/
data/processed/

# ---------------------------------------------------------------------------
# Python virtual environments — any of these common locations
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/
multimodal_ssl_pipeline/   # venv was previously created with this name inside the project
# If venv is created at project root: python -m venv .
pyvenv.cfg
lib/
bin/
include/
Scripts/
Lib/

# ---------------------------------------------------------------------------
# Python bytecode / caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.hypothesis/

# ---------------------------------------------------------------------------
# Logs (regenerated on each run)
# ---------------------------------------------------------------------------
logs/

# ---------------------------------------------------------------------------
# OS-specific files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# IDE and editor files
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Temporary / partial downloads
# ---------------------------------------------------------------------------
*.part
*.tmp

# =============================================================================
# What IS committed:
#   setup_data.sh, setup.bat, download_datasets.py
#   preprocess.py, validate_outputs.py
#   configs/, tests/, reports/
#   submission_sample/ (100 representative samples per dataset)
#   requirements.txt, requirements_pinned.txt
#   README.md, .gitignore
# =============================================================================
